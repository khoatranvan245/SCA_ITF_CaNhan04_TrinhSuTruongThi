// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Role {
  role_id     Int      @id @default(autoincrement())
  title       String
  description String?
  created_at  DateTime @default(now())

  users User[]
}

model User {
  user_id       Int      @id @default(autoincrement())
  email         String   @unique
  password_hash String
  role_id       Int
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  role       Role        @relation(fields: [role_id], references: [role_id])
  companies  Company[]
  candidates Candidate[]
}

model Company {
  company_id  Int      @id @default(autoincrement())
  name        String
  description String?
  website     String?
  avatar_url  String?
  category_id Int?
  user_id     Int
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
  city_id     Int?
  address     String?

  user     User      @relation(fields: [user_id], references: [user_id])
  category Category? @relation(fields: [category_id], references: [category_id])
  city     City?     @relation(fields: [city_id], references: [city_id])
  jobs     Job[]
}

model Category {
  category_id Int      @id @default(autoincrement())
  title       String
  description String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  jobs      Job[]
  companies Company[]
}

model Job {
  job_id           Int       @id @default(autoincrement())
  title            String
  description      String?
  requirements     String?
  experience_years Int?      @default(0)
  salary_min       Int?
  salary_max       Int?
  benefits         String?
  status           JobStatus @default(open)
  expiration_date  DateTime?
  category_id      Int
  company_id       Int
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt

  category Category @relation(fields: [category_id], references: [category_id])
  company  Company  @relation(fields: [company_id], references: [company_id])

  applications Application[]
  job_skills   JobSkill[]
}

model Candidate {
  candidate_id Int     @id @default(autoincrement())
  full_name    String
  phone        String?
  avatar_url   String?
  user_id      Int
  city_id      Int

  user User @relation(fields: [user_id], references: [user_id])
  city City @relation(fields: [city_id], references: [city_id])

  resumes          Resume[]
  applications     Application[]
  candidate_skills CandidateSkill[]
}

model Resume {
  resume_id    Int      @id @default(autoincrement())
  candidate_id Int
  name         String
  file_url     String
  uploaded_at  DateTime @default(now())
  isProfile    Boolean  @default(false)

  candidate    Candidate     @relation(fields: [candidate_id], references: [candidate_id])
  applications Application[]
}

model Application {
  application_id Int               @id @default(autoincrement())
  candidate_id   Int
  job_id         Int
  resume_id      Int
  cover_letter   String?
  status         ApplicationStatus @default(pending)
  created_at     DateTime          @default(now())
  updated_at     DateTime          @updatedAt

  candidate Candidate @relation(fields: [candidate_id], references: [candidate_id])
  job       Job       @relation(fields: [job_id], references: [job_id])
  resume    Resume    @relation(fields: [resume_id], references: [resume_id])

  ai_evaluations AIEvaluation[]
}

model AIEvaluation {
  ai_evaluation_id Int      @id @default(autoincrement())
  application_id   Int
  score            Float?
  matching_skills  String?
  missing_skills   String?
  summary          String?
  created_at       DateTime @default(now())

  application Application @relation(fields: [application_id], references: [application_id])
}

model Skill {
  skill_id   Int      @id @default(autoincrement())
  name       String
  created_at DateTime @default(now())

  job_skills       JobSkill[]
  candidate_skills CandidateSkill[]
}

model JobSkill {
  job_id   Int
  skill_id Int

  job   Job   @relation(fields: [job_id], references: [job_id])
  skill Skill @relation(fields: [skill_id], references: [skill_id])

  @@id([job_id, skill_id])
}

model CandidateSkill {
  candidate_id Int
  skill_id     Int

  candidate Candidate @relation(fields: [candidate_id], references: [candidate_id])
  skill     Skill     @relation(fields: [skill_id], references: [skill_id])

  @@id([candidate_id, skill_id])
}

model City {
  city_id    Int      @id @default(autoincrement())
  name       String
  created_at DateTime @default(now())

  companies  Company[]
  candidates Candidate[]
}

enum JobStatus {
  open
  closed
  pending
  expired
}

enum ApplicationStatus {
  pending
  reviewing
  rejected
  accepted
}
